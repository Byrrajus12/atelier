{
  "model": "claude-opus-4-8",
  "includeCoAuthoredBy": false,
  "hooks": {
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/subagent-gate.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/c/Users/HP/.local/bin/graphify.EXE hook-guard search"
          }
        ]
      },
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "/c/Users/HP/.local/bin/graphify.EXE hook-guard read"
          }
        ]
      }
    ]
  }
}